# Financial Modeling Prep API key (https://site.financialmodelingprep.com/)
FMP_API_KEY=your_fmp_key_here

# Shared secret the Vercel Cron job sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=generate_a_long_random_string

# Upstash Redis — provided automatically when you add the "Upstash Redis"
# integration from the Vercel Marketplace (Storage tab). The integration may set
# either UPSTASH_* or KV_* names; the app reads both. Leave blank for local dev:
# the store falls back to data/snapshot.json.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Data sources (Yahoo Finance + SEC EDGAR) are KEYLESS — no API key required.

# SEC asks for a descriptive User-Agent with contact info on its API requests.
# A plain "name email" string works; URLs/parentheses get blocked by its WAF.
# Optional — a sensible default is used if unset.
SEC_USER_AGENT=your-app-name your-email@example.com

# How many ranked companies each category page shows (default 200).
RANKING_LIMIT=200

# Size of the candidate pool discovered from Yahoo's screener each refresh
# (default 600). Keep it >= RANKING_LIMIT.
UNIVERSE_SIZE=600

# Shared secret the Vercel Cron job sends as `Authorization: Bearer <CRON_SECRET>`.
# Required only for the deployed /api/cron/refresh endpoint.
CRON_SECRET=generate_a_long_random_string

# Upstash Redis — provided automatically when you add the "Upstash Redis"
# integration from the Vercel Marketplace (Storage tab). The integration may set
# either UPSTASH_* or KV_* names; the app reads both. Leave blank for local dev:
# the store falls back to data/snapshot.json.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
